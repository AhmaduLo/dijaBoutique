# ============================================================
# VARIABLES D'ENVIRONNEMENT - Dija Saliou
# ============================================================
# Ce fichier montre les variables nécessaires pour l'application
# NE JAMAIS committer le vrai fichier .env avec vos vraies clés !

# ============================================================
# BASE DE DONNÉES (PRODUCTION)
# ============================================================
# En développement: configuré dans application.properties
# En production: OBLIGATOIRE
DATABASE_URL=jdbc:mysql://localhost:3306/dijasaliou_prod
DATABASE_USERNAME=votre_utilisateur_db
DATABASE_PASSWORD=votre_mot_de_passe_db

# ============================================================
# JWT - Token d'authentification
# ============================================================
# CRITIQUE: Générer un secret fort avec: openssl rand -base64 64
# OBLIGATOIRE en production, optionnel en dev (valeur par défaut existe)
JWT_SECRET=votre_secret_jwt_genere_avec_openssl_rand_base64_64

# ============================================================
# STRIPE - Paiements par carte bancaire
# ============================================================
# Pour obtenir vos clés: https://dashboard.stripe.com/apikeys
# TEST: pk_test_... et sk_test_... (pour développement)
# PRODUCTION: pk_live_... et sk_live_... (pour production)

STRIPE_PUBLIC_KEY=pk_test_VOTRE_CLE_PUBLIQUE_ICI
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE_ICI
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET_ICI

# ============================================================
# WAVE - Mobile Money Sénégal
# ============================================================
# Pour obtenir vos clés: Contacter business@wave.com
# Laisser vide en développement (mode simulation automatique)

WAVE_API_KEY=
WAVE_API_SECRET=
WAVE_API_URL=https://api.wave.com/v1
WAVE_WEBHOOK_URL=http://localhost:8080/api/payment/wave/webhook

# ============================================================
# EMAIL - Configuration SMTP
# ============================================================
# Gmail recommandé avec App Password
# Pour créer un App Password: https://myaccount.google.com/apppasswords

MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-app-gmail
APP_EMAIL_FROM=noreply@dijasaliou.com
APP_EMAIL_SUPPORT=support@dijasaliou.com

# ============================================================
# APPLICATION
# ============================================================
# URL du frontend (pour les liens dans les emails)
APP_FRONTEND_URL=http://localhost:4200

# Port du serveur (optionnel, par défaut 8080)
PORT=8080
